{
  "extends": "../../tsconfig.node.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./lib",
    "outDir": "./dist",
    "declaration": true,
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false
  },
  "include": ["lib/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
