{
  "name": "@gatherle/mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "apk:release": "node ./scripts/prepare-android-firebase-config.mjs && expo prebuild --no-install --platform android && npm run android:prepare:signing && ./android/gradlew -p android app:assembleRelease -PreactNativeArchitectures=arm64-v8a --build-cache --parallel -Dorg.gradle.caching=true",
    "apk:install": "sh -c 'if [ -n \"$ANDROID_SERIAL\" ]; then adb -s \"$ANDROID_SERIAL\" install -r android/app/build/outputs/apk/release/app-release.apk; else adb install -r android/app/build/outputs/apk/release/app-release.apk; fi'",
    "android:oauth:doctor": "node ./scripts/android-google-oauth-doctor.mjs",
    "android:prepare:signing": "node ./scripts/prepare-android-release-signing.mjs",
    "build": "npm-run-all codegen typecheck export",
    "build:android": "expo export --platform android --output-dir dist/android",
    "build:ios": "expo export --platform ios --output-dir dist/ios",
    "build:web": "expo export --platform web --output-dir dist/web",
    "codegen": "graphql-codegen",
    "eas:android": "eas build --platform android --verbose-logs",
    "eas:ios": "eas build --platform ios --verbose-logs",
    "eas-build-post-install": "npm run emit-schema -w @gatherle/api && npm run codegen",
    "export": "expo export --platform all --output-dir dist",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "expo start --dev-client",
    "start:tunnel": "expo start --tunnel --dev-client --clear",
    "start:lan": "expo start --host lan --dev-client --clear",
    "start:web": "expo start --web",
    "test:unit": "jest --config=test/unit/jest.config.js --runInBand",
    "native:sync": "node ./scripts/prepare-android-firebase-config.mjs && expo prebuild --no-install",
    "native:sync:clean": "node ./scripts/prepare-android-firebase-config.mjs && expo prebuild --clean --no-install",
    "typecheck": "tsc --project tsconfig.json --noEmit --pretty",
    "android": "node ./scripts/prepare-android-firebase-config.mjs && expo prebuild --no-install && npm run android:prepare:signing && expo run:android --no-install --device",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@apollo/client": "^3.14.1",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.2",
    "@gatherle/commons": "^1.0.0",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.16.0",
    "@react-navigation/material-top-tabs": "^7.4.26",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.0",
    "expo": "~54.0.35",
    "expo-apple-authentication": "~8.0.8",
    "expo-application": "~7.0.8",
    "expo-calendar": "~15.0.8",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.11",
    "graphql": "^16.13.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-pager-view": "6.9.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/client-preset": "^5.2.4",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.7.0",
    "@types/react": "~19.1.10",
    "@typescript-eslint/parser": "^8.56.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~54.0.10",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "npm-run-all": "^4.1.5",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
