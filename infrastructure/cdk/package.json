{
  "name": "@gatherle/cdk",
  "version": "1.0.0",
  "dependencies": {
    "@gatherle/commons": "1.0.0"
  },
  "scripts": {
    "build": "npm run build:ts",
    "build:ts": "tsc --project tsconfig.json --pretty",
    "build:cdk": "npm run cdk synth",
    "build:cdk:dns": "npm run cdk:dns synth",
    "build:cdk:github-auth": "npm run cdk:github-auth synth",
    "build:cdk:secrets": "npm run cdk:secrets synth",
    "cdk": "npx aws-cdk",
    "cdk:dns": "npx aws-cdk --app \"npx ts-node --project ./tsconfig.json --prefer-ts-exts ./lib/dns-app.ts\"",
    "cdk:github-auth": "npx aws-cdk --app \"npx ts-node --project ./tsconfig.json --prefer-ts-exts ./lib/github-auth-app.ts\"",
    "cdk:secrets": "npx aws-cdk --app \"npx ts-node --project ./tsconfig.json --prefer-ts-exts ./lib/secrets-app.ts\"",
    "clean": "node -e \"require('fs').rmSync('cdk.out', { recursive: true, force: true })\""
  },
  "devDependencies": {
    "aws-cdk": "^2.1117.0",
    "aws-cdk-lib": "^2.248.0",
    "dotenv": "^16.6.1",
    "esbuild": "^0.27.7"
  }
}
