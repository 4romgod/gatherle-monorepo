{
  "name": "@gatherle/commons",
  "version": "1.0.0",
  "description": "This repository contains common source code for gatherle",
  "main": "dist/server/index.js",
  "types": "dist/server/index.d.ts",
  "exports": {
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./server/constants": {
      "types": "./dist/server/constants/index.d.ts",
      "default": "./dist/server/constants/index.js"
    },
    "./server/types": {
      "types": "./dist/server/types/index.d.ts",
      "default": "./dist/server/types/index.js"
    },
    "./server/utils": {
      "types": "./dist/server/utils/index.d.ts",
      "default": "./dist/server/utils/index.js"
    },
    "./server/validation": {
      "types": "./dist/server/validation/index.d.ts",
      "default": "./dist/server/validation/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./client/constants": {
      "types": "./dist/client/constants/index.d.ts",
      "default": "./dist/client/constants/index.js"
    },
    "./client/utils": {
      "types": "./dist/client/utils/index.d.ts",
      "default": "./dist/client/utils/index.js"
    },
    "./client/validation": {
      "types": "./dist/client/validation/index.d.ts",
      "default": "./dist/client/validation/index.js"
    }
  },
  "scripts": {
    "build": "npm-run-all lint:check build:ts",
    "build:ts": "npm run clean && tsc --build tsconfig.json --pretty",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "tsc --build tsconfig.json --watch --preserveWatchOutput --pretty",
    "lint:check": "eslint \"lib/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"lib/**/*.{ts,tsx}\" --fix",
    "typecheck": "tsc --project tsconfig.json --noEmit --pretty"
  },
  "dependencies": {
    "@typegoose/typegoose": "^13.3.0",
    "date-fns": "^3.6.0",
    "graphql": "^16.13.2",
    "graphql-type-json": "^0.3.2",
    "mongoose": "~9.6.0",
    "reflect-metadata": "^0.2.2",
    "type-graphql": "^2.0.0-rc.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript": "^6.0.2"
  }
}
