{
  "extends": "../../tsconfig.node.json",
  "compilerOptions": {
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "noEmit": true,
    "types": ["node", "jest"],
    "paths": {
      "@gatherle/commons": ["packages/commons/lib/index.ts"],
      "@gatherle/commons/*": ["packages/commons/lib/*.ts", "packages/commons/lib/*/index.ts"],
      "@/test/*": ["apps/api/test/*.ts", "apps/api/test/*/index.ts"],
      "@/*": ["apps/api/lib/*.ts", "apps/api/lib/*/index.ts"]
    }
  },
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  },
  "include": ["lib/**/*.ts", "test/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
