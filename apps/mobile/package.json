{
  "name": "@gatherle/mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "apk:release": "expo prebuild --no-install && ./android/gradlew -p android app:assembleRelease",
    "apk:install": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "build": "npm run typecheck && expo export --platform all --output-dir dist",
    "build:android": "expo export --platform android --output-dir dist/android",
    "build:ios": "expo export --platform ios --output-dir dist/ios",
    "build:web": "expo export --platform web --output-dir dist/web",
    "codegen": "graphql-codegen --config codegen.ts",
    "eas:android": "eas build --platform android --verbose-logs",
    "eas:ios": "eas build --platform ios --verbose-logs",
    "eas-build-post-install": "npm run codegen",
    "start": "expo start",
    "start:tunnel": "expo start --tunnel --clear",
    "start:lan": "expo start --host lan --clear",
    "start:web": "expo start --web",
    "run:android": "expo run:android",
    "run:ios": "expo run:ios",
    "native:sync": "expo prebuild --no-install",
    "native:sync:clean": "expo prebuild --clean --no-install",
    "typecheck": "tsc --project tsconfig.json --noEmit --pretty"
  },
  "dependencies": {
    "@apollo/client": "^3.14.1",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/metro-runtime": "~55.0.11",
    "@expo/vector-icons": "^15.0.2",
    "@react-navigation/bottom-tabs": "^7.16.0",
    "@react-navigation/material-top-tabs": "^7.4.26",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.0",
    "expo": "~55.0.24",
    "expo-calendar": "~55.0.14",
    "expo-font": "~55.0.7",
    "expo-linear-gradient": "~55.0.14",
    "expo-secure-store": "~55.0.14",
    "expo-status-bar": "~55.0.6",
    "graphql": "^16.13.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-pager-view": "^8.0.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/client-preset": "^5.2.4",
    "@types/node": "^25.7.0",
    "@types/react": "~19.2.10",
    "babel-plugin-module-resolver": "^5.0.3",
    "dotenv": "^16.6.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
