{
  "name": "@gatherle/webapp",
  "private": true,
  "scripts": {
    "build": "npm-run-all codegen lint:check build:ts build:next",
    "build:ts": "tsc --project tsconfig.json --pretty",
    "build:next": "NEXT_SKIP_ESLINT=1 next build --webpack",
    "clean": "node -e \"for (const dir of ['.next', '.vercel']) require('fs').rmSync(dir, { recursive: true, force: true })\"",
    "clean:dev": "npm run clean",
    "prepare:schema": "npm --prefix ../.. run emit-schema -w @gatherle/api",
    "codegen": "npm-run-all prepare:schema codegen:run",
    "codegen:run": "graphql-codegen",
    "codegen:watch": "npm-run-all prepare:schema codegen:watch:run",
    "codegen:watch:run": "graphql-codegen --watch",
    "dev": "npm-run-all codegen start:dev",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "start:dev": "next dev",
    "start:prod": "next start",
    "test:unit": "jest --config=test/unit/jest.config.ts --runInBand",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@apollo/client": "^3.14.1",
    "@apollo/client-integration-nextjs": "^0.12.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@heroicons/react": "^2.2.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/material-nextjs": "^7.3.9",
    "@mui/x-date-pickers": "^7.29.4",
    "@tailwindcss/forms": "^0.5.11",
    "autoprefixer": "10.4.15",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dayjs": "^1.11.20",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.1",
    "next": "^16.2.2",
    "next-auth": "^5.0.0-beta.19",
    "nprogress": "^0.2.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "rrule": "^2.8.1",
    "tailwindcss": "^3.4.19",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/client-preset": "^5.2.4",
    "@parcel/watcher": "^2.5.6",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/style-guide": "^0.1.0",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "eslint-config-prettier": "9.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "graphql": "^16.13.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22.x"
  }
}
