{
  "expo": {
    "name": "Gatherle",
    "slug": "gatherle-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/favicon/orbit/light/android-chrome-512x512.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.gatherlemobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/favicon/orbit/light/android-chrome-512x512.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.anonymous.gatherlemobile"
    },
    "web": {
      "favicon": "./assets/favicon/orbit/light/favicon-32x32.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-video",
      [
        "@react-native-community/datetimepicker",
        {
          "android": {
            "datePicker": {
              "colorAccent": {
                "light": "#5850ec",
                "dark": "#7a73ff"
              },
              "colorControlActivated": {
                "light": "#5850ec",
                "dark": "#7a73ff"
              },
              "colorControlHighlight": {
                "light": "#ede9fe",
                "dark": "#2a2575"
              },
              "textColorPrimary": {
                "light": "#0b1736",
                "dark": "#f8fafc"
              },
              "textColorSecondary": {
                "light": "#667085",
                "dark": "#cbd5e1"
              },
              "windowBackground": {
                "light": "#ffffff",
                "dark": "#0f151a"
              }
            },
            "timePicker": {
              "background": {
                "light": "#ffffff",
                "dark": "#0f151a"
              },
              "headerBackground": {
                "light": "#5850ec",
                "dark": "#7a73ff"
              },
              "numbersBackgroundColor": {
                "light": "#ffffff",
                "dark": "#0f151a"
              },
              "numbersSelectorColor": {
                "light": "#ede9fe",
                "dark": "#2a2575"
              },
              "numbersTextColor": {
                "light": "#0b1736",
                "dark": "#f8fafc"
              }
            }
          }
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "7eee58bf-18f8-4b6d-a0a4-128a5d1f037b"
      }
    }
  }
}
