{
  "name": "gatherle",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/mobile",
    "apps/webapp",
    "packages/*",
    "infrastructure/cdk"
  ],
  "scripts": {
    "build": "npm run build:commons && npm run build:api && npm run build:web && npm run build:mobile && npm run build:cdk",
    "build:api": "npm run build -w @gatherle/api",
    "build:web": "npm run build -w @gatherle/webapp",
    "build:mobile": "npm run build -w @gatherle/mobile",
    "build:cdk": "npm run build -w @gatherle/cdk",
    "build:commons": "npm run build -w @gatherle/commons",
    "clean": "npm run clean --workspaces --if-present",
    "dev:commons": "npm run dev -w @gatherle/commons",
    "dev:api": "npm run dev -w @gatherle/api",
    "dev:mobile": "npm-run-all build:commons --parallel dev:commons dev:mobile:app",
    "dev:mobile:app": "npm run start -w @gatherle/mobile",
    "dev:mobile:lan": "npm-run-all build:commons --parallel dev:commons dev:mobile:lan:app",
    "dev:mobile:lan:app": "npm run start:lan -w @gatherle/mobile",
    "dev:mobile:tunnel": "npm-run-all build:commons --parallel dev:commons dev:mobile:tunnel:app",
    "dev:mobile:tunnel:app": "npm run start:tunnel -w @gatherle/mobile",
    "dev:web": "npm-run-all build:commons --parallel dev:commons dev:web:app",
    "dev:web:app": "npm run dev -w @gatherle/webapp",
    "lint": "npm run lint:check",
    "lint:check": "npm-run-all lint:check:commons-boundary lint:check:workspaces lint:check:ops-cli",
    "lint:check:commons-boundary": "node ./scripts/check-commons-boundaries.mjs",
    "lint:check:workspaces": "npm run lint:check --workspaces --if-present",
    "lint:check:ops-cli": "uv run --project apps/ops-cli ruff check apps/ops-cli",
    "lint:fix": "npm run lint:fix:workspaces && npm run lint:fix:ops-cli && npm run format:write && npm run format:write:ops-cli",
    "lint:fix:workspaces": "npm run lint:fix --workspaces --if-present",
    "lint:fix:ops-cli": "uv run --project apps/ops-cli ruff check --fix apps/ops-cli",
    "format:write": "prettier --write \"**/*.{js,ts,tsx,mjs,cjs,json,md}\" --cache",
    "format:write:ops-cli": "uv run --project apps/ops-cli ruff format apps/ops-cli",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:unit": "npm run test:unit:api && npm run test:unit:web && npm run test:unit:mobile",
    "test:unit:api": "npm run test:unit -w @gatherle/api",
    "test:unit:mobile": "npm run test:unit -w @gatherle/mobile",
    "test:unit:web": "npm run test:unit -w @gatherle/webapp",
    "test:e2e:api": "npm run test:e2e -w @gatherle/api --",
    "test:e2e:web": "npm run test:e2e -w @gatherle/webapp --"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "dotenv": "^16.6.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "mongoose": "~9.6.0"
  }
}
