{
  "compilerOptions": {
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@gatherle/commons/client": ["packages/commons/lib/client/index.ts"],
      "@gatherle/commons/client/*": ["packages/commons/lib/client/*.ts", "packages/commons/lib/client/*/index.ts"],
      "@gatherle/commons/server": ["packages/commons/lib/server/index.ts"],
      "@gatherle/commons/server/*": ["packages/commons/lib/server/*.ts", "packages/commons/lib/server/*/index.ts"]
    }
  }
}
