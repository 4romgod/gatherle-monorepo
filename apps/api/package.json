{
  "name": "@gatherle/api",
  "version": "1.0.0",
  "description": "This npm workspace contains the business logic for the gatherle graphql api",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "scripts": {
    "build": "npm-run-all lint:check build:ts",
    "build:ts": "npm run clean && tsc --build tsconfig.build.json --pretty",
    "build:node": "node -r ts-node/register -r tsconfig-paths/register",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "emit-schema": "ts-node lib/scripts/emit-schema.ts",
    "build:image": "docker build -t gatherle-backend .",
    "dev": "nodemon lib/scripts/startServer.ts",
    "start:ts": "ts-node lib/scripts/startServer.ts",
    "start:js": "node -r ts-node/register -r tsconfig-paths/register dist/lib/scripts/startServer.js",
    "seed": "ts-node lib/scripts/seed.ts",
    "geocode-events": "ts-node lib/scripts/geocode-events.ts",
    "lint:check": "eslint \"lib/**/*.{ts,tsx}\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"lib/**/*.{ts,tsx}\" \"test/**/*.ts\" --fix",
    "typecheck": "tsc --project tsconfig.json --noEmit --pretty",
    "test": "npm-run-all test:*",
    "test:canary": "jest --config=test/canary/jest.config.ts",
    "test:e2e": "jest --config=test/e2e/jest.config.ts",
    "test:unit": "jest --config=test/unit/jest.config.ts --runInBand"
  },
  "dependencies": {
    "@apollo/server": "^4.13.0",
    "@as-integrations/aws-lambda": "^3.1.0",
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1024.0",
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/client-secrets-manager": "^3.1024.0",
    "@aws-sdk/client-ses": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@gatherle/commons": "1.0.0",
    "@typegoose/typegoose": "^12.21.1",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.4",
    "class-validator": "^0.14.4",
    "cors": "^2.8.6",
    "dataloader": "^2.2.3",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.1",
    "mongoose": "~8.21.1",
    "reflect-metadata": "^0.2.2",
    "rrule": "^2.8.1",
    "tsconfig-paths": "^4.2.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.10",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.39.4",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "directories": {
    "lib": "lib",
    "test": "test"
  }
}
