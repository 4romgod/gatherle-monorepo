{
  "compilerOptions": {
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@gatherle/commons": ["packages/commons/lib/index.ts"],
      "@gatherle/commons/types": ["packages/commons/lib/types/index.ts"],
      "@gatherle/commons/types/*": ["packages/commons/lib/types/*.ts", "packages/commons/lib/types/*/index.ts"],
      "@gatherle/commons/*": ["packages/commons/lib/*.ts", "packages/commons/lib/*/index.ts"]
    }
  }
}
